#include <windows.h>
#include <commctrl.h>

#ifndef IDC_STATIC
#define IDC_STATIC -1
#endif

// 图标资源定义
#define IDI_ICON_NORMAL    101
#define IDI_ICON_DISABLED  102

// 配置对话框 ID 和控件 ID
#define IDD_CONFIG_DIALOG    200
#define IDC_TAB             201
#define IDC_LOG_PATH        202
#define IDC_BROWSE_LOG      203
#define IDC_MODEL_PATH      204
#define IDC_BROWSE_MODEL    205
#define IDC_MAPPING_LIST    206
#define IDC_BTN_ADD         207
#define IDC_BTN_EDIT        208
#define IDC_BTN_REMOVE      209
#define IDC_BTN_RESET       210

// 添加/编辑映射对话框
#define IDD_MAPPING_DIALOG  300
#define IDC_FROM_KEY        301
#define IDC_TO_KEY          302

// 图标资源
IDI_ICON_NORMAL    ICON    "icon.ico"
IDI_ICON_DISABLED  ICON    "icon_disabled.ico"

// 版本信息
1 VERSIONINFO
FILEVERSION     0,1,2,0
PRODUCTVERSION  0,1,2,0
FILEFLAGSMASK   0x3f
FILEFLAGS       0x0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404b0"
        BEGIN
            VALUE "CompanyName", "John"
            VALUE "FileDescription", "PowerCapslock - Windows keyboard remapping and speech input tool"
            VALUE "FileVersion", "0.1.2.preview"
            VALUE "InternalName", "PowerCapslock"
            VALUE "LegalCopyright", "Copyright (C) 2024 John. MIT License."
            VALUE "OriginalFilename", "powercapslock.exe"
            VALUE "ProductName", "PowerCapslock"
            VALUE "ProductVersion", "0.1.2.preview"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x804, 1200
    END
END

// 主配置对话框
IDD_CONFIG_DIALOG DIALOGEX 0, 0, 380, 260
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "PowerCapslock Configuration"
FONT 9, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_TAB, WC_TABCONTROL, WS_TABSTOP, 7, 7, 366, 210
    DEFPUSHBUTTON   "OK",IDOK, 220, 225, 70, 25
    PUSHBUTTON      "Cancel",IDCANCEL, 300, 225, 70, 25
END

// 添加/编辑按键映射对话框
IDD_MAPPING_DIALOG DIALOGEX 0, 0, 200, 100
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add/Edit Mapping"
FONT 9, "MS Shell Dlg"
BEGIN
    CTEXT           "From:",IDC_STATIC,10,10,60,14
    EDITTEXT        IDC_FROM_KEY,75,10,110,14,ES_AUTOHSCROLL
    CTEXT           "To:",IDC_STATIC,10,35,60,14
    EDITTEXT        IDC_TO_KEY,75,35,110,14,ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",IDOK,50,65,60,20
    PUSHBUTTON      "Cancel",IDCANCEL,120,65,60,20
END
